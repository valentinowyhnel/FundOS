generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  investor
  founder
  admin
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  role      UserRole
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  investor  Investor?
  founder   Founder?
}

model Investor {
  id                  String   @id @default(uuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id])
  firstName           String
  lastName            String
  accreditationStatus Boolean  @default(false)
  preferences         Json?    // InvestorPreferences
  investments         Investment[]
}

model Founder {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  firstName   String
  lastName    String
  companyName String
  linkedinUrl String?
  campaigns   Campaign[]
}

enum CampaignStatus {
  draft
  published
  funded
  closed
}

enum CampaignStage {
  seed
  series_a
  series_b
  growth
}

model Campaign {
  id           String         @id @default(uuid())
  founderId    String
  founder      Founder        @relation(fields: [founderId], references: [id])
  title        String
  description  String
  targetAmount Decimal        @db.Decimal(20, 2)
  raisedAmount Decimal        @db.Decimal(20, 2) @default(0)
  status       CampaignStatus @default(draft)
  sector       String
  stage        CampaignStage
  location     String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  documents    CampaignDocument[]
  investments  Investment[]
}

model CampaignDocument {
  id         String   @id @default(uuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id])
  name       String
  url        String
  type       String
  createdAt  DateTime @default(now())
}

model Investment {
  id         String   @id @default(uuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id])
  investorId String
  investor   Investor @relation(fields: [investorId], references: [id])
  amount     Decimal  @db.Decimal(20, 2)
  currency   String   @default("USD")
  status     String   @default("pending") // pending, confirmed, failed
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model KycRecord {
  id         String   @id @default(uuid())
  userId     String   @unique
  status     String   // pending, approved, rejected
  data       Json?
  updatedAt  DateTime @updatedAt
}
