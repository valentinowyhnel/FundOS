{
  "name": "fundos",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "typecheck": "turbo run typecheck",
    "format": "biome check --write .",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "clean": "turbo run clean",
    "prepare": "husky",
    "agents:build": "turbo run build --filter=\"@fundos/agent-*\"",
    "agents:test": "turbo run test --filter=\"@fundos/agent-*\"",
    "agents:typecheck": "turbo run typecheck --filter=\"@fundos/agent-*\""
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@types/node": "^25.9.3",
    "@types/react": "18.3.31",
    "@types/react-dom": "18.3.7",
    "dotenv-cli": "^8.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "tsx": "^4.19.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "dependencies": {
    "@google-cloud/vertexai": "^1.12.0",
    "@google/genai": "^2.8.0"
  }
}
